4365:bmi2.c        ****  * @brief This API performs self-test to check the proper functionality of the
4366:bmi2.c        ****  * accelerometer sensor.
4367:bmi2.c        ****  */
4368:bmi2.c        **** int8_t bmi2_perform_accel_self_test(struct bmi2_dev *dev)
4369:bmi2.c        **** {
4370:bmi2.c        ****     /* Variable to define error */
4371:bmi2.c        ****     int8_t rslt;
4372:bmi2.c        **** 
4373:bmi2.c        ****     /* Variable to store self-test result */
4374:bmi2.c        ****     int8_t st_rslt = 0;
4375:bmi2.c        **** 
4376:bmi2.c        ****     /* Structure to define positive accelerometer axes */
4377:bmi2.c        ****     struct bmi2_sens_axes_data positive = { 0, 0, 0, 0 };
4378:bmi2.c        **** 
4379:bmi2.c        ****     /* Structure to define negative accelerometer axes */
4380:bmi2.c        ****     struct bmi2_sens_axes_data negative = { 0, 0, 0, 0 };
4381:bmi2.c        **** 
4382:bmi2.c        ****     /* Structure for difference of accelerometer values in g */
4383:bmi2.c        ****     struct bmi2_selftest_delta_limit accel_data_diff = { 0, 0, 0 };
4384:bmi2.c        **** 
4385:bmi2.c        ****     /* Structure for difference of accelerometer values in mg */
4386:bmi2.c        ****     struct bmi2_selftest_delta_limit accel_data_diff_mg = { 0, 0, 0 };
4387:bmi2.c        **** 
4388:bmi2.c        ****     /* Initialize the polarity of self-test as positive */
4389:bmi2.c        ****     int8_t sign = BMI2_ENABLE;
4390:bmi2.c        **** 
4391:bmi2.c        ****     /* Null-pointer check */
4392:bmi2.c        ****     rslt = null_ptr_check(dev);
4393:bmi2.c        ****     if (rslt == BMI2_OK)
4394:bmi2.c        ****     {
4395:bmi2.c        ****         /* Sets the configuration required before enabling self-test */
4396:bmi2.c        ****         rslt = pre_self_test_config(dev);
4397:bmi2.c        **** 
4398:bmi2.c        ****         /* Wait for greater than 2 milliseconds */
4399:bmi2.c        ****         dev->delay_us(3000, dev->intf_ptr);
4400:bmi2.c        ****         if (rslt == BMI2_OK)
4401:bmi2.c        ****         {
4402:bmi2.c        ****             do
4403:bmi2.c        ****             {
4404:bmi2.c        ****                 /* Select positive first, then negative polarity
4405:bmi2.c        ****                  * after enabling self-test
4406:bmi2.c        ****                  */
4407:bmi2.c        ****                 rslt = self_test_config((uint8_t) sign, dev);
4408:bmi2.c        ****                 if (rslt == BMI2_OK)
4409:bmi2.c        ****                 {
4410:bmi2.c        ****                     /* Wait for greater than 50 milli-sec */
4411:bmi2.c        ****                     dev->delay_us(51000, dev->intf_ptr);
4412:bmi2.c        **** 
4413:bmi2.c        ****                     /* If polarity is positive */
4414:bmi2.c        ****                     if (sign == BMI2_ENABLE)
4415:bmi2.c        ****                     {
4416:bmi2.c        ****                         /* Read and store positive acceleration value */
4417:bmi2.c        ****                         rslt = read_accel_xyz(&positive, dev);
4418:bmi2.c        ****                     }
4419:bmi2.c        ****                     /* If polarity is negative */
4420:bmi2.c        ****                     else if (sign == BMI2_DISABLE)
ARM GAS  C:\Users\amala\AppData\Local\Temp\ccQVMkbW.s 			page 79


4421:bmi2.c        ****                     {
4422:bmi2.c        ****                         /* Read and store negative acceleration value */
4423:bmi2.c        ****                         rslt = read_accel_xyz(&negative, dev);
4424:bmi2.c        ****                     }
4425:bmi2.c        ****                 }
4426:bmi2.c        ****                 else
4427:bmi2.c        ****                 {
4428:bmi2.c        ****                     /* Break if error */
4429:bmi2.c        ****                     break;
4430:bmi2.c        ****                 }
4431:bmi2.c        **** 
4432:bmi2.c        ****                 /* Break if error */
4433:bmi2.c        ****                 if (rslt != BMI2_OK)
4434:bmi2.c        ****                 {
4435:bmi2.c        ****                     break;
4436:bmi2.c        ****                 }
4437:bmi2.c        **** 
4438:bmi2.c        ****                 /* Turn the polarity of self-test negative */
4439:bmi2.c        ****                 sign--;
4440:bmi2.c        ****             } while (sign >= 0);
4441:bmi2.c        ****             if (rslt == BMI2_OK)
4442:bmi2.c        ****             {
4443:bmi2.c        ****                 /* Subtract -ve acceleration values from that of +ve values */
4444:bmi2.c        ****                 accel_data_diff.x = (positive.x) - (negative.x);
4445:bmi2.c        ****                 accel_data_diff.y = (positive.y) - (negative.y);
4446:bmi2.c        ****                 accel_data_diff.z = (positive.z) - (negative.z);
4447:bmi2.c        **** 
4448:bmi2.c        ****                 /* Convert differences of acceleration values
4449:bmi2.c        ****                  * from 'g' to 'mg'
4450:bmi2.c        ****                  */
4451:bmi2.c        ****                 convert_lsb_g(&accel_data_diff, &accel_data_diff_mg, dev);
4452:bmi2.c        **** 
4453:bmi2.c        ****                 /* Validate self-test for acceleration values
4454:bmi2.c        ****                  * in mg and get the self-test result
4455:bmi2.c        ****                  */
4456:bmi2.c        ****                 st_rslt = validate_self_test(&accel_data_diff_mg);
4457:bmi2.c        **** 
4458:bmi2.c        ****                 /* Trigger a soft reset after performing self-test */
4459:bmi2.c        ****                 rslt = bmi2_soft_reset(dev);
4460:bmi2.c        **** 
4461:bmi2.c        ****                 /* Return the self-test result */
4462:bmi2.c        ****                 if (rslt == BMI2_OK)
4463:bmi2.c        ****                 {
4464:bmi2.c        ****                     rslt = st_rslt;
4465:bmi2.c        ****                 }
4466:bmi2.c        ****             }
4467:bmi2.c        ****         }
4468:bmi2.c        ****     }
4469:bmi2.c        **** 
4470:bmi2.c        ****     return rslt;
4471:bmi2.c        **** }
