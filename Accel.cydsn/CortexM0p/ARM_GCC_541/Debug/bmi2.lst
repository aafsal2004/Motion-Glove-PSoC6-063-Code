11525:bmi2.c        ****             {
11526:bmi2.c        ****                 temp_foc_data.z = temp_foc_data.z * BMI2_FOC_INVERT_VALUE;
11527:bmi2.c        ****             }
11528:bmi2.c        ****         }
11529:bmi2.c        **** 
11530:bmi2.c        ****         avg_foc_data.x = (int16_t)(temp_foc_data.x);
11531:bmi2.c        ****         avg_foc_data.y = (int16_t)(temp_foc_data.y);
11532:bmi2.c        ****         avg_foc_data.z = (int16_t)(temp_foc_data.z);
11533:bmi2.c        **** 
11534:bmi2.c        ****         rslt = validate_foc_position(sens_list, accel_g_axis, avg_foc_data, dev);
11535:bmi2.c        ****     }
11536:bmi2.c        **** 
11537:bmi2.c        ****     return rslt;
11538:bmi2.c        **** }
