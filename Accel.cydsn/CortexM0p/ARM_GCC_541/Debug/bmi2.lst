8662:bmi2.c        ****             }
8663:bmi2.c        **** 
8664:bmi2.c        ****             fifo->acc_frm_len = BMI2_FIFO_ACC_LENGTH;
8665:bmi2.c        ****             fifo->gyr_frm_len = BMI2_FIFO_GYR_LENGTH;
