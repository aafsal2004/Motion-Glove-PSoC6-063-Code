4576:bmi2.c        ****                      */
4577:bmi2.c        ****                     reg_data |= (int1_mask | int2_mask);
4578:bmi2.c        ****                     break;
4579:bmi2.c        ****                 default:
4580:bmi2.c        ****                     break;
4581:bmi2.c        ****             }
4582:bmi2.c        **** 
4583:bmi2.c        ****             /* Set the interrupts in the map register */
4584:bmi2.c        ****             rslt = bmi2_set_regs(BMI2_INT_MAP_DATA_ADDR, &reg_data, 1, dev);
