5421:bmi2.c        ****             }
5422:bmi2.c        **** 
5423:bmi2.c        ****             /* Restore the saved gyroscope configurations */
5424:bmi2.c        ****             if (rslt == BMI2_OK)
5425:bmi2.c        ****             {
