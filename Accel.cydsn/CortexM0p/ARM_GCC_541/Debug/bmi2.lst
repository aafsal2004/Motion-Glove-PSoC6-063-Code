5413:bmi2.c        ****                  */
5414:bmi2.c        ****                 rslt = bmi2_write_gyro_offset_comp_axes(&gyro_offset, dev);
5415:bmi2.c        ****             }
5416:bmi2.c        **** 
5417:bmi2.c        ****             /* Enable gyroscope offset compensation */
5418:bmi2.c        ****             if (rslt == BMI2_OK)
