8148:bmi2.c        ****                                           uint16_t *aux_length,
8149:bmi2.c        ****                                           struct bmi2_fifo_frame *fifo,
8150:bmi2.c        ****                                           const struct bmi2_dev *dev)
8151:bmi2.c        **** {
8152:bmi2.c        ****     int8_t rslt;
8153:bmi2.c        **** 
8154:bmi2.c        ****     /* Variable to index the bytes */
