4563:bmi2.c        ****                     reg_data |= int1_mask;
4564:bmi2.c        ****                     break;
4565:bmi2.c        ****                 case BMI2_INT2:
4566:bmi2.c        **** 
4567:bmi2.c        ****                     /* Map the corresponding data interrupt to
4568:bmi2.c        ****                      * interrupt pin 2
