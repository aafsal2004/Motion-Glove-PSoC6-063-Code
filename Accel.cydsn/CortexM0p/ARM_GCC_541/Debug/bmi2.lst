9417:bmi2.c        ****     uint8_t acc_conf_data = BMI2_FOC_ACC_CONF_VAL;
9418:bmi2.c        **** 
9419:bmi2.c        ****     /* Disabling offset compensation */
9420:bmi2.c        ****     rslt = bmi2_set_accel_offset_comp(BMI2_DISABLE, dev);
9421:bmi2.c        ****     if (rslt == BMI2_OK)
9422:bmi2.c        ****     {
9423:bmi2.c        ****         /* Set accelerometer configurations to 50Hz, continuous mode, CIC mode */
9424:bmi2.c        ****         rslt = bmi2_set_regs(BMI2_ACC_CONF_ADDR, &acc_conf_data, 1, dev);
9425:bmi2.c        ****         if (rslt == BMI2_OK)
9426:bmi2.c        ****         {
9427:bmi2.c        ****             /* Set accelerometer to normal mode by enabling it */
9428:bmi2.c        ****             rslt = bmi2_sensor_enable(&sens_list, 1, dev);
9429:bmi2.c        **** 
9430:bmi2.c        ****             if (rslt == BMI2_OK)
9431:bmi2.c        ****             {
9432:bmi2.c        ****                 /* Disable advance power save mode */
9433:bmi2.c        ****                 rslt = bmi2_set_adv_power_save(BMI2_DISABLE, dev);
9434:bmi2.c        ****             }
9435:bmi2.c        ****         }
9436:bmi2.c        ****     }
9437:bmi2.c        **** 
9438:bmi2.c        ****     return rslt;
9439:bmi2.c        **** }
