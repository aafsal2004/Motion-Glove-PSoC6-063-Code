8156:bmi2.c        **** 
8157:bmi2.c        ****     /* Variable to index auxiliary frames */
8158:bmi2.c        ****     uint16_t aux_index = 0;
8159:bmi2.c        **** 
8160:bmi2.c        ****     /* Variable to store the number of bytes to be read */
8161:bmi2.c        ****     uint16_t data_read_length = 0;
8162:bmi2.c        **** 
