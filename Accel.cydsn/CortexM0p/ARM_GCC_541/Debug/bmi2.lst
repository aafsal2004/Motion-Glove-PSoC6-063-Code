8183:bmi2.c        **** 
8184:bmi2.c        ****             if (rslt != BMI2_W_FIFO_EMPTY)
8185:bmi2.c        ****             {
8186:bmi2.c        ****                 /* Check for the availability of next two bytes of FIFO data */
8187:bmi2.c        ****                 rslt = check_empty_fifo(&data_index, fifo);
8188:bmi2.c        ****             }
8189:bmi2.c        ****         }
8190:bmi2.c        ****     }
8191:bmi2.c        **** 
