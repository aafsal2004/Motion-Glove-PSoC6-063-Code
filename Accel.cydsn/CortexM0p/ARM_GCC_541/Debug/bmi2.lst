6584:bmi2.c        **** /*!
6585:bmi2.c        ****  * @brief This internal API reads the user-defined bytes of data from the given
6586:bmi2.c        ****  * register address of auxiliary sensor in manual mode.
6587:bmi2.c        ****  */
6588:bmi2.c        **** static int8_t read_aux_data(uint8_t reg_addr, uint8_t *aux_data, uint16_t len, uint8_t burst_len, s
6589:bmi2.c        **** {
6590:bmi2.c        ****     /* Variable to define error */
6591:bmi2.c        ****     int8_t rslt = BMI2_OK;
6592:bmi2.c        **** 
6593:bmi2.c        ****     /* Array to store the register data */
6594:bmi2.c        ****     uint8_t reg_data[15] = { 0 };
6595:bmi2.c        **** 
6596:bmi2.c        ****     /* Variable to define number of bytes to read */
6597:bmi2.c        ****     uint16_t read_length = 0;
6598:bmi2.c        **** 
6599:bmi2.c        ****     /* Variable to define loop */
6600:bmi2.c        ****     uint8_t loop = 0;
6601:bmi2.c        **** 
6602:bmi2.c        ****     /* Variable to define counts to get the correct array index */
6603:bmi2.c        ****     uint8_t count = 0;
6604:bmi2.c        **** 
6605:bmi2.c        ****     /* Variable to define index for the array */
6606:bmi2.c        ****     uint8_t idx = 0;
6607:bmi2.c        **** 
6608:bmi2.c        ****     while (len > 0)
6609:bmi2.c        ****     {
6610:bmi2.c        ****         /* Set the read address if AUX is not busy */
6611:bmi2.c        ****         rslt = set_if_aux_not_busy(BMI2_AUX_RD_ADDR, reg_addr, dev);
6612:bmi2.c        ****         if (rslt == BMI2_OK)
6613:bmi2.c        ****         {
6614:bmi2.c        ****             /* Read data from bmi2 data register */
6615:bmi2.c        ****             rslt = bmi2_get_regs(BMI2_AUX_X_LSB_ADDR, reg_data, (uint16_t) burst_len, dev);
6616:bmi2.c        ****             dev->delay_us(1000, dev->intf_ptr);
6617:bmi2.c        ****             if (rslt == BMI2_OK)
6618:bmi2.c        ****             {
6619:bmi2.c        ****                 /* Get number of bytes to be read */
6620:bmi2.c        ****                 if (len < burst_len)
6621:bmi2.c        ****                 {
6622:bmi2.c        ****                     read_length = (uint8_t) len;
ARM GAS  C:\Users\amala\AppData\Local\Temp\ccQVMkbW.s 			page 123


6623:bmi2.c        ****                 }
6624:bmi2.c        ****                 else
6625:bmi2.c        ****                 {
6626:bmi2.c        ****                     read_length = burst_len;
6627:bmi2.c        ****                 }
6628:bmi2.c        **** 
6629:bmi2.c        ****                 /* Update array index and store the data */
6630:bmi2.c        ****                 for (loop = 0; loop < read_length; loop++)
6631:bmi2.c        ****                 {
6632:bmi2.c        ****                     idx = loop + count;
6633:bmi2.c        ****                     aux_data[idx] = reg_data[loop];
6634:bmi2.c        ****                 }
6635:bmi2.c        ****             }
6636:bmi2.c        ****         }
6637:bmi2.c        **** 
6638:bmi2.c        ****         /* Update address for the next read */
6639:bmi2.c        ****         reg_addr += burst_len;
6640:bmi2.c        **** 
6641:bmi2.c        ****         /* Update count for the array index */
6642:bmi2.c        ****         count += burst_len;
6643:bmi2.c        **** 
6644:bmi2.c        ****         /* Update no of bytes left to read */
6645:bmi2.c        ****         len -= read_length;
6646:bmi2.c        ****     }
6647:bmi2.c        **** 
6648:bmi2.c        ****     return rslt;
