8816:bmi2.c        **** /*!
8817:bmi2.c        ****  * @brief This internal API enables and configures the accelerometer which is
8818:bmi2.c        ****  * needed for self-test operation. It also sets the amplitude for the self-test.
8819:bmi2.c        ****  */
8820:bmi2.c        **** static int8_t pre_self_test_config(struct bmi2_dev *dev)
8821:bmi2.c        **** {
8822:bmi2.c        ****     /* Variable to define error */
8823:bmi2.c        ****     int8_t rslt;
8824:bmi2.c        **** 
8825:bmi2.c        ****     /* Structure to define sensor configurations */
8826:bmi2.c        ****     struct bmi2_sens_config sens_cfg;
8827:bmi2.c        **** 
8828:bmi2.c        ****     /* List the sensors to be selected */
8829:bmi2.c        ****     uint8_t sens_sel = BMI2_ACCEL;
8830:bmi2.c        **** 
8831:bmi2.c        ****     /* Enable accelerometer */
8832:bmi2.c        ****     rslt = bmi2_sensor_enable(&sens_sel, 1, dev);
8833:bmi2.c        ****     dev->delay_us(1000, dev->intf_ptr);
8834:bmi2.c        **** 
8835:bmi2.c        ****     /* Enable self-test amplitude */
8836:bmi2.c        ****     if (rslt == BMI2_OK)
8837:bmi2.c        ****     {
8838:bmi2.c        ****         rslt = set_accel_self_test_amp(BMI2_ENABLE, dev);
8839:bmi2.c        ****     }
8840:bmi2.c        **** 
8841:bmi2.c        ****     if (rslt == BMI2_OK)
8842:bmi2.c        ****     {
ARM GAS  C:\Users\amala\AppData\Local\Temp\ccQVMkbW.s 			page 223


8843:bmi2.c        ****         /* Select accelerometer for sensor configurations */
8844:bmi2.c        ****         sens_cfg.type = BMI2_ACCEL;
8845:bmi2.c        **** 
8846:bmi2.c        ****         /* Get the default values */
8847:bmi2.c        ****         rslt = bmi2_get_sensor_config(&sens_cfg, 1, dev);
8848:bmi2.c        ****         if (rslt == BMI2_OK)
8849:bmi2.c        ****         {
8850:bmi2.c        ****             /* Set the configurations required for self-test */
8851:bmi2.c        ****             sens_cfg.cfg.acc.odr = BMI2_ACC_ODR_1600HZ;
8852:bmi2.c        ****             sens_cfg.cfg.acc.bwp = BMI2_ACC_NORMAL_AVG4;
8853:bmi2.c        ****             sens_cfg.cfg.acc.filter_perf = BMI2_PERF_OPT_MODE;
8854:bmi2.c        ****             sens_cfg.cfg.acc.range = BMI2_ACC_RANGE_16G;
8855:bmi2.c        **** 
8856:bmi2.c        ****             /* Set accelerometer configurations */
8857:bmi2.c        ****             rslt = bmi2_set_sensor_config(&sens_cfg, 1, dev);
8858:bmi2.c        ****         }
8859:bmi2.c        ****     }
8860:bmi2.c        **** 
8861:bmi2.c        ****     return rslt;
8862:bmi2.c        **** }
8863:bmi2.c        **** 
8864:bmi2.c        **** /*!
8865:bmi2.c        ****  * @brief This internal API performs the steps needed for self-test operation
8866:bmi2.c        ****  * before reading the accelerometer self-test data.
8867:bmi2.c        ****  */
8868:bmi2.c        **** static int8_t self_test_config(uint8_t sign, struct bmi2_dev *dev)
8869:bmi2.c        **** {
8870:bmi2.c        ****     /* Variable to define error */
8871:bmi2.c        ****     int8_t rslt;
8872:bmi2.c        **** 
8873:bmi2.c        ****     /* Enable the accelerometer self-test feature */
8874:bmi2.c        ****     rslt = set_accel_self_test_enable(BMI2_ENABLE, dev);
8875:bmi2.c        ****     if (rslt == BMI2_OK)
8876:bmi2.c        ****     {
8877:bmi2.c        ****         /* Selects the sign of accelerometer self-test excitation */
8878:bmi2.c        ****         rslt = set_acc_self_test_sign(sign, dev);
8879:bmi2.c        ****     }
8880:bmi2.c        **** 
8881:bmi2.c        ****     return rslt;
8882:bmi2.c        **** }
8883:bmi2.c        **** 
8884:bmi2.c        **** /*!
8885:bmi2.c        ****  * @brief This internal API enables or disables the accelerometer self-test
8886:bmi2.c        ****  * feature in the sensor.
8887:bmi2.c        ****  */
8888:bmi2.c        **** static int8_t set_accel_self_test_enable(uint8_t enable, struct bmi2_dev *dev)
8889:bmi2.c        **** {
8890:bmi2.c        ****     /* Variable to define error */
8891:bmi2.c        ****     int8_t rslt;
8892:bmi2.c        **** 
8893:bmi2.c        ****     /* Variable to define data */
8894:bmi2.c        ****     uint8_t data = 0;
8895:bmi2.c        **** 
8896:bmi2.c        ****     /* Enable/Disable self-test feature */
8897:bmi2.c        ****     rslt = bmi2_get_regs(BMI2_ACC_SELF_TEST_ADDR, &data, 1, dev);
8898:bmi2.c        ****     if (rslt == BMI2_OK)
8899:bmi2.c        ****     {
ARM GAS  C:\Users\amala\AppData\Local\Temp\ccQVMkbW.s 			page 224


8900:bmi2.c        ****         data = BMI2_SET_BIT_POS0(data, BMI2_ACC_SELF_TEST_EN, enable);
8901:bmi2.c        ****         rslt = bmi2_set_regs(BMI2_ACC_SELF_TEST_ADDR, &data, 1, dev);
8902:bmi2.c        ****     }
8903:bmi2.c        **** 
8904:bmi2.c        ****     return rslt;
8905:bmi2.c        **** }
