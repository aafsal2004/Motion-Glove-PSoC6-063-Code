  74:main_cm0p.c   **** static void BMI270_PrepareConfigLoad(void)
  75:main_cm0p.c   **** {
  76:main_cm0p.c   ****     // Disable advanced power save: PWR_CONF[0] = adv_power_save = 0
  77:main_cm0p.c   ****     WriteRegister(0x7C, 0x00);
  78:main_cm0p.c   ****     CyDelayUs(500);   // Bosch says >= 450 us
  79:main_cm0p.c   **** 
  80:main_cm0p.c   ****     // Prepare config load
  81:main_cm0p.c   ****     WriteRegister(0x59, 0x00);   // INIT_CTRL = 0x00
  82:main_cm0p.c   **** 
  83:main_cm0p.c   ****     // Start config address at 0
  84:main_cm0p.c   ****     WriteRegister(0x5B, 0x00);   // INIT_ADDR_0
  85:main_cm0p.c   ****     WriteRegister(0x5C, 0x00);   // INIT_ADDR_1
  86:main_cm0p.c   **** }
