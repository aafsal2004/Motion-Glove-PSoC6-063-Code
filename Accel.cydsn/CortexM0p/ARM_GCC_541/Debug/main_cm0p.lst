 107:main_cm0p.c   **** static void BMI270_UploadConfig(const uint8 *config_file, uint16 config_size)
 108:main_cm0p.c   **** {
 109:main_cm0p.c   ****     uint16 index = 0;
 110:main_cm0p.c   ****     uint16 chunk;
 111:main_cm0p.c   **** 
 112:main_cm0p.c   ****     while(index < config_size)
 113:main_cm0p.c   ****     {
 114:main_cm0p.c   ****         chunk = config_size - index;
 115:main_cm0p.c   **** 
 116:main_cm0p.c   ****         if(chunk > 32)
 117:main_cm0p.c   ****         {
 118:main_cm0p.c   ****             chunk = 32;
 119:main_cm0p.c   ****         }
 120:main_cm0p.c   **** 
 121:main_cm0p.c   ****         WriteBurst(0x5E, &config_file[index], chunk);   // INIT_DATA
 122:main_cm0p.c   ****         index += chunk;
 123:main_cm0p.c   ****     }
 124:main_cm0p.c   **** }
